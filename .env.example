# Copy this file to .env.local and fill local values.
# Never commit .env.local.

# OpenRouter key from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Local URL used in OpenRouter HTTP-Referer metadata.
OPENROUTER_SITE_URL=http://localhost:3004

# Human-readable app title sent to OpenRouter.
OPENROUTER_APP_NAME=Reverie Image Production Pipeline

# FAL key for image utilities such as background removal.
# Create it at https://fal.ai/dashboard/keys
FAL_API_KEY=

# Telegram bot token used by /api/telegram/* routes.
TELEGRAM_BOT_TOKEN=

# PostgreSQL connection used by Better Auth and product data.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/image_prodaction
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000

# Better Auth. Generate a local secret with: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3004
BETTER_AUTH_SECRET=
NEXT_PUBLIC_BETTER_AUTH_URL=

# S3-compatible private storage. Local defaults target MinIO.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=image-prodaction-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=900
S3_MAX_IMAGE_BYTES=15728640
