# Copy this file to .env.local and fill local values.
# Never commit .env.local.

# OpenRouter key from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Local URL used in OpenRouter HTTP-Referer metadata.
OPENROUTER_SITE_URL=http://localhost:3004

# Human-readable app title sent to OpenRouter.
OPENROUTER_APP_NAME=Reverie Image Production Pipeline

# A generation attempt can be recovered after this worker lease expires.
# Allowed range: 60-3600 seconds. The local default is five minutes.
GENERATION_JOB_LEASE_SECONDS=300

# FAL key for image utilities such as background removal.
# Create it at https://fal.ai/dashboard/keys
FAL_API_KEY=

# Telegram bot token used by /api/telegram/* routes.
TELEGRAM_BOT_TOKEN=

# PostgreSQL connection used by Better Auth and product data.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/image_prodaction
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=10000
DATABASE_IDLE_TIMEOUT_MS=30000

# Better Auth. Generate a local secret with: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3004
BETTER_AUTH_SECRET=
NEXT_PUBLIC_BETTER_AUTH_URL=
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3004

# Authentication policy. Keep verification mandatory locally so the complete
# journey is exercised. Set to false only as an explicit operational rollback.
AUTH_REQUIRE_EMAIL_VERIFICATION=true
AUTH_EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=3600
AUTH_PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# Transactional email transport. Local defaults target Mailpit from Compose:
# SMTP is captured locally and visible at http://localhost:8025.
# Production may later replace this transport with Unisender Go.
EMAIL_TRANSPORT=smtp
EMAIL_FROM=Reverie <no-reply@reverie.local>
EMAIL_REPLY_TO=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAILPIT_HTTP_URL=http://localhost:8025

# S3-compatible private storage. Local defaults target MinIO.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=image-prodaction-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=900
S3_MAX_IMAGE_BYTES=15728640
