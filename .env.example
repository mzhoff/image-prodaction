# Copy this file to .env.local and fill local values.
# Never commit .env.local.

# OpenRouter key from https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Local URL used in OpenRouter HTTP-Referer metadata.
OPENROUTER_SITE_URL=http://localhost:3004

# Human-readable app title sent to OpenRouter.
OPENROUTER_APP_NAME=Reverie Image Production Pipeline

# FAL key for image utilities such as background removal.
# Create it at https://fal.ai/dashboard/keys
FAL_API_KEY=

# PostgreSQL connection string for Better Auth and Drizzle.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/image_prodaction

# Better Auth base URL and secret.
# Generate a local secret with: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3004
BETTER_AUTH_SECRET=

# Browser client base URL. Leave empty when the app and API share the same origin.
NEXT_PUBLIC_BETTER_AUTH_URL=
