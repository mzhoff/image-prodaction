#!/usr/bin/env bash
set -euo pipefail

if [[ "${EUID}" -ne 0 ]]; then
  printf 'provision-stage must run as root.\n' >&2
  exit 1
fi

bundle_root="${1:?bundle root is required}"
ci_public_key_file="${2:?CI public key file is required}"
deploy_root=/opt/image-prodaction
deploy_user=deploy

install -d -m 750 -o "$deploy_user" -g "$deploy_user" \
  "$deploy_root" \
  "$deploy_root/deploy" \
  "$deploy_root/deploy/server"
install -m 755 -o root -g root \
  "$bundle_root/deploy/server/reverie-ci-deploy" \
  /usr/local/sbin/reverie-ci-deploy
install -m 750 -o "$deploy_user" -g "$deploy_user" \
  "$bundle_root/deploy/server/reverie-backup" \
  "$deploy_root/deploy/server/reverie-backup"
install -m 750 -o "$deploy_user" -g "$deploy_user" \
  "$bundle_root/deploy/server/reverie-create-user" \
  "$deploy_root/deploy/server/reverie-create-user"
install -m 640 -o "$deploy_user" -g "$deploy_user" \
  "$bundle_root/compose.production.yaml" \
  "$deploy_root/compose.production.yaml"
install -m 640 -o "$deploy_user" -g "$deploy_user" \
  "$bundle_root/deploy/Caddyfile" \
  "$deploy_root/deploy/Caddyfile"
install -d -m 700 -o "$deploy_user" -g "$deploy_user" /var/backups/reverie

install_ci_key() {
  local authorized_keys filtered_keys
  authorized_keys="/home/$deploy_user/.ssh/authorized_keys"
  filtered_keys="$(mktemp)"
  grep -v 'github-actions-image-prodaction' "$authorized_keys" > "$filtered_keys" || true
  {
    cat "$filtered_keys"
    printf 'restrict,command="/usr/local/sbin/reverie-ci-deploy" '
    cat "$ci_public_key_file"
  } > "$authorized_keys.tmp"
  install -m 600 -o "$deploy_user" -g "$deploy_user" \
    "$authorized_keys.tmp" "$authorized_keys"
  rm -f "$filtered_keys" "$authorized_keys.tmp"
}

create_runtime_environment() {
  local environment_file
  if [[ -s "$deploy_root/.env.production" ]]; then
    return
  fi

  local postgres_password minio_user minio_password auth_secret
  local provider_master provider_fingerprint
  postgres_password="$(openssl rand -hex 32)"
  minio_user="$(openssl rand -hex 16)"
  minio_password="$(openssl rand -hex 32)"
  auth_secret="$(openssl rand -base64 48 | tr -d '\n')"
  provider_master="$(openssl rand -base64 32 | tr -d '\n')"
  provider_fingerprint="$(openssl rand -base64 32 | tr -d '\n')"
  environment_file="$(mktemp)"

  printf '%s\n' \
    'PUBLIC_APP_URL=https://reverieapp.ru' \
    'PUBLIC_TRUSTED_ORIGINS=https://reverieapp.ru' \
    'POSTGRES_DB=image_prodaction' \
    'POSTGRES_USER=reverie' \
    "POSTGRES_PASSWORD=$postgres_password" \
    "DATABASE_URL=postgresql://reverie:$postgres_password@postgres:5432/image_prodaction" \
    "MINIO_ROOT_USER=$minio_user" \
    "MINIO_ROOT_PASSWORD=$minio_password" \
    'S3_REGION=us-east-1' \
    'S3_BUCKET=image-prodaction-assets' \
    "S3_ACCESS_KEY_ID=$minio_user" \
    "S3_SECRET_ACCESS_KEY=$minio_password" \
    'S3_FORCE_PATH_STYLE=true' \
    'S3_MAX_IMAGE_BYTES=15728640' \
    "BETTER_AUTH_SECRET=$auth_secret" \
    'AUTH_ALLOW_SIGN_UP=false' \
    'AUTH_REQUIRE_EMAIL_VERIFICATION=false' \
    'EMAIL_TRANSPORT=disabled' \
    "PROVIDER_CREDENTIALS_MASTER_KEY=$provider_master" \
    'PROVIDER_CREDENTIALS_MASTER_KEY_VERSION=v1' \
    "PROVIDER_CREDENTIALS_FINGERPRINT_KEY=$provider_fingerprint" \
    'AI_PROVIDER_RUNTIME=openrouter' \
    'WORKER_READY_FILE=/tmp/reverie-generation-worker-ready' \
    'WORKER_HEALTH_STALE_AFTER_MS=45000' \
    > "$environment_file"

  install -m 600 -o "$deploy_user" -g "$deploy_user" \
    "$environment_file" "$deploy_root/.env.production"
  rm -f "$environment_file"
}

install_backup_timer() {
  cat > /etc/systemd/system/reverie-backup.service <<'UNIT'
[Unit]
Description=Create local Reverie staging backup
After=docker.service
ConditionPathExists=/opt/image-prodaction/.release.env

[Service]
Type=oneshot
User=deploy
Group=deploy
ExecStart=/opt/image-prodaction/deploy/server/reverie-backup
UNIT
  cat > /etc/systemd/system/reverie-backup.timer <<'UNIT'
[Unit]
Description=Daily Reverie staging backup

[Timer]
OnCalendar=*-*-* 02:15:00
RandomizedDelaySec=30m
Persistent=true

[Install]
WantedBy=timers.target
UNIT
}

install_ci_key
create_runtime_environment
install_backup_timer

systemctl daemon-reload
systemctl enable --now reverie-backup.timer
systemctl enable --now unattended-upgrades.service

printf 'server-provisioning=complete\n'
printf 'runtime-env-mode='
stat -c '%a %U:%G' "$deploy_root/.env.production"
printf 'authorized-key-count='
grep -c '^' "/home/$deploy_user/.ssh/authorized_keys"
