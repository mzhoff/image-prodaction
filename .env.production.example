# This file documents the remote single-host environment.
# Real values live only on the server in /opt/image-prodaction/.env.production.

APP_IMAGE_TAG=current
APP_BASE_URL=https://89.124.115.57

POSTGRES_DB=image_prodaction
POSTGRES_USER=reverie
POSTGRES_PASSWORD=replace-with-a-long-random-value
DATABASE_URL=postgresql://reverie:replace-with-a-long-random-value@postgres:5432/image_prodaction

MINIO_ROOT_USER=replace-with-a-random-access-key
MINIO_ROOT_PASSWORD=replace-with-a-long-random-secret
S3_REGION=us-east-1
S3_BUCKET=image-prodaction-assets
S3_ACCESS_KEY_ID=replace-with-a-random-access-key
S3_SECRET_ACCESS_KEY=replace-with-a-long-random-secret
S3_FORCE_PATH_STYLE=true
S3_MAX_IMAGE_BYTES=15728640

BETTER_AUTH_URL=https://89.124.115.57
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_TRUSTED_ORIGINS=https://89.124.115.57
AUTH_REQUIRE_EMAIL_VERIFICATION=false
EMAIL_TRANSPORT=disabled

PROVIDER_CREDENTIALS_MASTER_KEY=replace-with-a-32-byte-base64-key
PROVIDER_CREDENTIALS_MASTER_KEY_VERSION=v1
PROVIDER_CREDENTIALS_FINGERPRINT_KEY=replace-with-another-32-byte-base64-key
AI_PROVIDER_RUNTIME=openrouter
OPENROUTER_SITE_URL=https://89.124.115.57

WORKER_READY_FILE=/tmp/reverie-generation-worker-ready
WORKER_HEALTH_STALE_AFTER_MS=45000
